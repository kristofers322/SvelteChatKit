# SvelteChatKit configuration
#
# All variables are optional — with no .env at all, the demo runs with the
# built-in mock provider so you can try the UI without any API.
#
# NOTE: PUBLIC_* variables are embedded in the client bundle and visible to
# anyone using your site. Put real keys here only for local development.
# In production, keep keys server-side and point the "custom" provider at
# your own proxy endpoint instead.

# Which provider the demo selects by default: mock | openai | ollama | dify | custom
PUBLIC_DEFAULT_PROVIDER=mock

# OpenAI-compatible (OpenAI, OpenRouter, Groq, LM Studio, vLLM, llama.cpp, ...)
PUBLIC_OPENAI_BASE_URL=https://api.openai.com/v1
PUBLIC_OPENAI_API_KEY=
PUBLIC_OPENAI_MODEL=gpt-4o-mini

# Dify
PUBLIC_DIFY_BASE_URL=https://api.dify.ai/v1
PUBLIC_DIFY_API_KEY=

# Ollama (local models — no key required)
PUBLIC_OLLAMA_BASE_URL=http://localhost:11434
PUBLIC_OLLAMA_MODEL=llama3.1

# Custom HTTP endpoint (your own backend/proxy; full URL)
PUBLIC_CUSTOM_ENDPOINT=
