# SvelteChatKit config. Everything is optional; with no .env the demo
# runs on the built-in mock provider (no API needed).
#
# NOTE: PUBLIC_* vars end up in the client bundle, visible to anyone.
# Local dev only. In production keep keys server-side behind a proxy.

# Which provider the demo selects by default: mock | openai | ollama | dify | n8n | custom
PUBLIC_DEFAULT_PROVIDER=mock

# OpenAI-compatible (OpenAI, OpenRouter, Groq, LM Studio, vLLM, llama.cpp, ...)
PUBLIC_OPENAI_BASE_URL=https://api.openai.com/v1
PUBLIC_OPENAI_API_KEY=
PUBLIC_OPENAI_MODEL=gpt-4o-mini

# Dify
PUBLIC_DIFY_BASE_URL=https://api.dify.ai/v1
PUBLIC_DIFY_API_KEY=

# Ollama (local models, no key required)
PUBLIC_OLLAMA_BASE_URL=http://localhost:11434
PUBLIC_OLLAMA_MODEL=llama3.1

# n8n (Chat Trigger production webhook URL, e.g. https://your-n8n.example.com/webhook/<id>/chat)
PUBLIC_N8N_WEBHOOK_URL=

# Custom HTTP endpoint (your own backend/proxy; full URL)
PUBLIC_CUSTOM_ENDPOINT=
