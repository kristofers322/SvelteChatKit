{
	"name": "sveltechatkit",
	"version": "0.1.1",
	"description": "A universal, provider-agnostic AI chat UI kit for SvelteKit — streaming responses, markdown rendering, and a clean provider abstraction for OpenAI-compatible APIs, Ollama, Dify, n8n, and custom backends.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kristofers322/SvelteChatKit.git"
	},
	"type": "module",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepack": "npm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"peerDependencies": {
		"@tailwindcss/typography": ">=0.5.0",
		"svelte": "^5.0.0",
		"tailwindcss": ">=3.4.0"
	},
	"peerDependenciesMeta": {
		"@tailwindcss/typography": {
			"optional": true
		},
		"tailwindcss": {
			"optional": true
		}
	},
	"dependencies": {
		"dompurify": "^3.2.3",
		"highlight.js": "^11.11.0",
		"marked": "^15.0.4",
		"marked-highlight": "^2.2.1"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.3.1",
		"@sveltejs/kit": "^2.15.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@tailwindcss/typography": "^0.5.15",
		"autoprefixer": "^10.4.20",
		"postcss": "^8.4.49",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"publint": "^0.3.21",
		"svelte": "^5.16.0",
		"svelte-check": "^4.1.1",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.7.2",
		"vite": "^6.0.7"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"ai",
		"chat",
		"chatbot",
		"ui-kit",
		"openai",
		"ollama",
		"dify",
		"llm",
		"streaming"
	]
}
